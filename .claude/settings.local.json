{
  "permissions": {
    "allow": [
      "Bash",
      "PowerShell",
      "Read(//d/**)",
      "Read(//c/Users/home/**)",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(format *)",
      "Bash(shutdown *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ],
    "additionalDirectories": [
      "d:\\dev",
      "d:\\mydocs",
      "C:\\Users\\home\\.claude"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude\\session-start-rules.ps1\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
